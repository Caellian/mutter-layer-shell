diff --git a/src/wayland/meta-wayland-layer-shell.c b/src/wayland/meta-wayland-layer-shell.c
new file mode 100644
index 0000000000..fa456c345b
--- /dev/null
+++ b/src/wayland/meta-wayland-layer-shell.c
@@ -0,0 +1,863 @@
